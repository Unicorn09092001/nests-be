enum EPermission {
  USER_VIEW
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  CATEGORY_VIEW
  CATEGORY_CREATE
  CATEGORY_UPDATE
  CATEGORY_DELETE
  BOOK_VIEW
  BOOK_CREATE
  BOOK_UPDATE
  BOOK_DELETE
  AUTHOR_VIEW
  AUTHOR_CREATE
  AUTHOR_UPDATE
  AUTHOR_DELETE
}

model Permission {
  id        String      @id @default(uuid())
  name      String      @unique
  code      EPermission @unique
  roles     Role[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("permission")
}
