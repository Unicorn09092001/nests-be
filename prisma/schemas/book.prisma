enum EBookStatus {
    AVAILABLE
    BORROWED
    MAINTENANCE
}

model Book {
    id            String         @id @default(uuid())
    title         String
    pageNumber    Int
    isbn          String         @unique
    status        EBookStatus
    categoryId    String
    category      Category       @relation(fields: [categoryId], references: [id])
    authors       Author[]
    borrowRecords BorrowRecord[]
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([categoryId])
    @@map("book")
}

model BorrowRecord {
    id         String    @id @default(uuid())
    borrowDate DateTime  @default(now())
    dueDate    DateTime
    returnDate DateTime?
    books      Book[]
    userId     String
    user       User      @relation("UserBorrowRecord", fields: [userId], references: [id])
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    @@index([userId])
    @@map("borrow_record")
}
