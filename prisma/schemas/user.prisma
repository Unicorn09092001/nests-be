model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String
  refreshToken    String?
  isEmailVerified Boolean        @default(false)
  roles           Role[]
  borrowRecords   BorrowRecord[] @relation("UserBorrowRecord")
  profile         Profile?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  codeId          String?
  codeExpired     DateTime?

  @@map("user")
}

model Profile {
  id      String  @id @default(uuid())
  name    String
  phone   String  @unique
  avatar  String?
  address String?
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profile")
}
