enum ERole {
    STUDENT
    INSTRUCTOR
}

enum EnrollmentStatus {
    PENDING
    PAID
    CANCELLED
}

model Users {
    id       String @id @default(uuid())
    name     String
    email    String @unique
    password String
    role     ERole

    // Quan he: Mot giang vien co the tao nhieu khoa hoc
    authoredCourses Courses[] @relation("InstructorCourses")

    // Quan he: Mot hoc vien co the dang ky nhieu khoa hoc thong qua bang Enrollments
    enrollments Enrollments[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("users") // Map ten bang trong DB la "users" (thuong dung so nhieu va chu thuong)
}

model Courses {
    id          String @id @default(uuid())
    title       String
    description String @db.Text // Dung @db.Text de luu duoc noi dung dai
    price       Float  @default(0)

    // Giang vien quan ly khoa hoc (1-n)
    instructorId String
    instructor   User   @relation("InstructorCourses", fields: [instructorId], references: [id])

    lessons     Lessons[]
    enrollments Enrollments[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("courses")
}

model Lessons {
    id       String  @id @default(uuid())
    order    Int
    videoUrl String
    courseId String
    course   Courses @relation(fields: [courseId], references: [id])

    createdAt DateTime @default(now())
    
    
    @@map("lessons")
}

model Enrollments {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    courseId String
    course   Courses @relation(fields: [courseId], references: [id], onDelete: Cascade)

    status EnrollmentStatus @default(PENDING)

    @@unique([userId, courseId]) // De mot hoc vien khong the dang ky trung 1 khoa hoc 2 lan
    @@map("enrollments")
}
