// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
  engineType   = "library"
}

datasource db {
  provider = "mysql"
}

model Author {
    id          String   @id @default(uuid())
    name        String
    description String   @db.Text()
    books       Book[]
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("author")
}


enum EBookStatus {
    AVAILABLE
    BORROWED
    MAINTENANCE
}

model Book {
    id            String         @id @default(uuid())
    title         String
    pageNumber    Int
    isbn          String         @unique
    status        EBookStatus
    categoryId    String
    category      Category       @relation(fields: [categoryId], references: [id])
    authors       Author[]
    borrowRecords BorrowRecord[]
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    @@index([categoryId])
    @@map("book")
}

model BorrowRecord {
    id         String    @id @default(uuid())
    borrowDate DateTime  @default(now())
    dueDate    DateTime
    returnDate DateTime?
    books      Book[]
    userId     String
    user       User      @relation("UserBorrowRecord", fields: [userId], references: [id])
    createdAt  DateTime  @default(now())
    updatedAt  DateTime  @updatedAt

    @@index([userId])
    @@map("borrow_record")
}


model Category {
    id        String   @id @default(uuid())
    name      String
    books     Book[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("category")
}


enum EPermission {
  USER_VIEW
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  CREATE_CATEGORY
  DELETE_CATEGORY
  UPDATE_CATEGORY
}

model Permission {
  id        String      @id @default(uuid())
  name      String      @unique
  code      EPermission @unique
  roles     Role[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("permission")
}


model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  users       User[]
  permissions Permission[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("role")
}

model User {
  id              String         @id @default(uuid())
  email           String         @unique
  password        String         @db.Text
  refreshToken    String?        @db.Text
  isEmailVerified Boolean        @default(false)
  roles           Role[]
  borrowRecords   BorrowRecord[] @relation("UserBorrowRecord")
  profile         Profile?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  codeId          String?
  codeExpired     DateTime?

  @@map("user")
}

model Profile {
  id      String  @id @default(uuid())
  name    String
  phone   String  @unique
  avatar  String?
  address String?
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profile")
}
